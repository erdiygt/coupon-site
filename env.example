# Public site URL (canonical, sitemap, Schema.org)
NEXT_PUBLIC_SITE_URL=https://www.ornekdomain.com

# Production: uygulama başlarken Supabase bağlantısı test edilir (instrumentation.ts)
# Eksik veya hatalıysa sunucu başlamaz.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin authentication (required)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!ChangeMe
SESSION_SECRET=dev-session-secret-change-me-min-32-chars!!

# Production: use hashed password instead of plain text
# Generate with: npm run auth:hash -- "your-strong-password"
# ADMIN_PASSWORD_HASH=scrypt:...

# Contact form (SMTP — required for /iletisim form)
CONTACT_RECIPIENT_EMAIL=yigiterdi05@gmail.com
CONTACT_FROM_EMAIL=hello@kuponkodlari.com.tr
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-app-password

# Upstash Redis (optional — distributed rate limiting; falls back to in-memory when unset)
# UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Social media (optional — override default profile URLs)
# NEXT_PUBLIC_SOCIAL_X_URL=https://x.com/kuponkodlarim
# NEXT_PUBLIC_SOCIAL_FACEBOOK_URL=https://facebook.com/kuponkodlarim
# NEXT_PUBLIC_SOCIAL_INSTAGRAM_URL=https://instagram.com/kuponkodlarim
# NEXT_PUBLIC_SOCIAL_TIKTOK_URL=https://tiktok.com/@kuponkodlarim
# NEXT_PUBLIC_SOCIAL_PINTEREST_URL=https://pinterest.com/kuponkodlarim
